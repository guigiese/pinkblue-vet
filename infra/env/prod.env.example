# Core app profile
PB_ENV=production
PB_TIMEZONE=America/Sao_Paulo
APP_URL=https://pinkblue-vet-production.up.railway.app
PB_CSRF_SECRET=replace-in-secret-store

# Database
DATABASE_URL=postgresql+psycopg2://pinkblue:replace-me@db-host:5432/pinkblue_prod

# Lab connectors
BITLAB_USUARIO=replace-in-secret-store
BITLAB_SENHA=replace-in-secret-store
BITLAB_CD_CONVENIO=1170
BITLAB_CD_POSTO=8
DIAS_ATRAS=60

NEXIO_USUARIO=replace-in-secret-store
NEXIO_SENHA=replace-in-secret-store

# Notifiers
TELEGRAM_TOKEN=replace-in-secret-store
TELEGRAM_CHATID=replace-if-still-needed
WHATSAPP_PHONE=replace-if-used
CALLMEBOT_APIKEY=replace-if-used

# AI providers
GOOGLE_AI_API_KEY=replace-if-used
GROQ_API_KEY=replace-if-used
ANTHROPIC_API_KEY=replace-if-used
OPENAI_API_KEY=replace-if-used
DEFAULT_AI_PROVIDER=gemini
DEFAULT_AI_MODEL=gemini-2.5-flash

# AI / worker feature flags
ON_DEMAND_AI_ENABLED=false
MONITOR_WORKER_ENABLED=false
DOWNSTREAM_WORKER_ENABLED=false
QA_WORKER_ENABLED=false

# Sidecar automation runtime
WORKER_RUNTIME=railway-only
AUTOMATION_BASE_URL=
N8N_WEBHOOK_BASE_URL=

# Environment policy flags
PR_ENVIRONMENTS_ENABLED=true
FIXED_STAGING_ENABLED=false
